FROM python:3.12-slim

#FROM python:3.12-alpine

#RUN apk add --no-cache ffmpeg ttf-dejavu busybox-extras libsndfile-dev
#RUN apk add --no-cache build-base cmake llvm20-dev llvm20-static libedit-dev
#RUN apk add --no-cache zlib-dev clang llvm20-gtest libsndfile

RUN apt-get install -y ffmpeg libsndfile-dev build-essential cmake libedit-dev clang zlib1g-dev

WORKDIR /app

COPY ./heket/*.py /app/
COPY ./heket/docker/run.sh /app/
RUN mkdir /app/models
COPY ./heket/models/* /app/models
RUN mkdir /app/web_assets
COPY ./heket/web_assets /app/web_assets
COPY ./heket/requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

RUN chmod +x /app/*.sh

VOLUME ["/data"]

CMD ["/app/run.sh"]
